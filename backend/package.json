{
  "name": "tienda-backend",
  "version": "1.0.0",
  "description": "API REST para TIENDA - Pedidos y catálogo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:wa": "node server.js",
    "dev:watch": "nodemon --watch server.js --watch src --ext js --delay 2 --ignore node_modules --ignore data --ignore uploads --ignore .wwebjs_auth --ignore .wwebjs_cache --ignore \"**/.wwebjs_*\" server.js",
    "dev:no-wa": "set WHATSAPP_ENABLED=false&& node server.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src"
    ],
    "ext": "js",
    "delay": 2000,
    "ignore": [
      "node_modules/**",
      "data/**",
      "uploads/**",
      ".wwebjs_auth/**",
      ".wwebjs_cache/**",
      "**/.wwebjs_*/**",
      "**/*.json"
    ]
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.0.15",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
