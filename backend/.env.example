# ============================================================
#  Variables de entorno del BACKEND (granjita-app en Render)
#  Copiar estos valores en Render -> Service granjita-app -> Environment
# ============================================================

# Puerto (Render lo asigna solo, pero se deja por defecto)
PORT=5000

NODE_ENV=production

# --- OBLIGATORIO en producción ---
# Base de datos MongoDB Atlas (NO uses localhost en Render).
# Crea un cluster gratis en https://www.mongodb.com/atlas y pega aquí la cadena:
# mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/granjita?retryWrites=true&w=majority
MONGODB_URI=

# Orígenes permitidos para CORS (el frontend). Separados por comas.
CORS_ORIGIN=https://granjita-frontend.onrender.com

# URL pública de la tienda (frontend)
STORE_URL=https://granjita-frontend.onrender.com

# Contraseña del panel admin (la que recibe el dueño)
ADMIN_PASSWORD=emadiana123

# Secreto para firmar los tokens JWT. Usa un valor largo y aleatorio.
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
