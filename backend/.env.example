# Servidor
PORT=5000
# production | development
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/tienda

# ── Seguridad (OBLIGATORIO cambiar en producción) ──
# Contraseña del panel admin (mín. 12 caracteres recomendado)
ADMIN_PASSWORD=cambia-esta-clave-por-una-larga
# Secreto JWT (mín. 32 caracteres aleatorios)
# Generá uno: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
# Caducidad del token admin
JWT_EXPIRES_IN=12h

# Frontend permitido (CORS). En producción SOLO tus dominios reales.
# Separados por coma. NO uses * en producción.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# URL pública de la tienda (links WhatsApp)
STORE_URL=http://127.0.0.1:3000

# WhatsApp dueño (código país + número, sin +)
OWNER_WHATSAPP=50254973412
WHATSAPP_ENABLED=true
WHATSAPP_AUTO_REPLY=true
WHATSAPP_FIRST_MSG_OF_DAY=true
# false = no mostrar QR en http://localhost:5000/ (recomendado)
WA_PUBLIC_PANEL=false
# Carpeta de sesión WA (por defecto: %USERPROFILE%\.tienda-wwebjs-auth)
# WA_AUTH_PATH=

# Opcional Chrome
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Mercado Pago (opcional)
MERCADOPAGO_ACCESS_TOKEN=
